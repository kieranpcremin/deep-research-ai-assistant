{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "WebResearchScraper": {
    "MaxResults": 10,
    "MaxConcurrency": 4,
    "StaticTimeoutSeconds": 15,
    "PlaywrightTimeoutMs": 30000,
    "MinContentLengthChars": 400
  }
}
